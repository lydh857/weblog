# ============================================
# 项目根目录 .gitignore
# ============================================

# 规范文档（本地开发用，不提交）
.claude/
.history/
# Docker 数据卷（包含数据库数据，不提交）
docker-data/
database/*
!database/weblog.sql
!database/sql/
!database/sql/init/
!database/sql/init/*.sql
# 文档文件夹（如果是临时文档）
docs/*
!scripts/p0-api-regression.ps1
*.txt
!weblog-backend/weblog-infra-security/src/main/resources/sensitive/sensi_words.txt
*.md
AGENTS.md
CLAUDE.md
# Docker Compose 配置（可能包含敏感信息）
docker-compose.yml
# docker-compose.prod.yml 由 GitHub Actions 上传到服务器，保留在仓库中
# 环境变量文件
.env
.env.local
.env.prod
*.env

# 操作系统文件
.DS_Store
Thumbs.db

# IDE 配置
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# Node.js（前端项目会用到）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Nuxt 构建产物
.nuxt/
.output/

# 构建产物
dist/
build/
target/
out/

# Lucene 运行时索引（本地生成，不提交）
weblog-backend/lucene-index/

# 本地上传目录（运行时生成，不提交）
weblog-backend/uploads/

# 备份文件
*.bak
*.backup

# 敏感文件和证书
*.pem
*.key
*.crt
*.pfx
