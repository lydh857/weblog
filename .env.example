# ============================================
# Weblog 环境变量模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env（开发环境）或 .env.prod（生产环境）
# 2. 将所有 <请替换> 占位符替换为你的实际配置
# 3. 生产环境请使用强随机密钥（可用 deploy/generate-secrets.sh 生成）
# ============================================

# ===== Database =====
MYSQL_ROOT_PASSWORD=<请替换为强密码>
DB_USERNAME=blog_user
DB_PASSWORD=<请替换为强密码>
# Flyway 迁移专用账户（可选，不填则回退使用 DB_USERNAME/DB_PASSWORD）
FLYWAY_USERNAME=blog_user
FLYWAY_PASSWORD=<请替换为强密码>

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=<请替换为强密码>

# ===== JWT（至少 32 字符）=====
# 生成方法：openssl rand -base64 48
JWT_SECRET=<请替换为至少32字符的随机字符串>

# ===== Captcha HMAC 签名密钥 =====
# 生成方法：openssl rand -base64 48
CAPTCHA_SECRET_KEY=<请替换为随机字符串>

# ===== CORS / 安全来源 =====
CORS_ORIGINS=https://yourdomain.com
# ALLOWED_ORIGINS 优先于 CORS_ORIGINS，未设置时回退到 CORS_ORIGINS
ALLOWED_ORIGINS=https://yourdomain.com
# HSTS / Referer 验证（生产环境 HTTPS 时启用）
HSTS_ENABLED=false
REFERER_ENABLED=true

# ===== 文件上传 URL 前缀 =====
UPLOAD_BASE_URL=https://yourdomain.com/uploads

# ===== API Base URL（SSR 内部调用）=====
API_BASE_URL=http://weblog-api:9091
API_INTERNAL_BASE_URL=http://weblog-api:9091

# ===== GitHub OAuth =====
# 在 https://github.com/settings/developers 创建 OAuth App
GITHUB_CLIENT_ID=<你的 GitHub OAuth Client ID>
GITHUB_CLIENT_SECRET=<你的 GitHub OAuth Client Secret>
# OAuth 回调域名（生产环境用，本地开发可不填）
OAUTH_ALLOWED_CALLBACKS=yourdomain.com

# ===== Import API =====
IMPORT_TOKEN=<请替换为随机字符串>

# ===== AI（可选）=====
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_MODEL=qwen-plus

# ===== 邮件 SMTP（可选）=====
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SSL_ENABLED=false
MAIL_FROM_NAME=Weblog
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_LOGO_URL=
MAIL_CODE_EXPIRE_MINUTES=5

# ===== 备用邮件通道（可选）=====
MAIL_FALLBACK_ENABLED=false
MAIL_FALLBACK_SMTP_HOST=
MAIL_FALLBACK_SMTP_PORT=587
MAIL_FALLBACK_USERNAME=
MAIL_FALLBACK_PASSWORD=
MAIL_FALLBACK_SSL_ENABLED=false

# ===== 存储后端选择 =====
# 可选值：local | aliyun-oss | r2（默认 local）
STORAGE_PROVIDER=local

# ===== 阿里云 OSS（STORAGE_PROVIDER=aliyun-oss 时生效）=====
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_CDN_DOMAIN=

# ===== Cloudflare R2（STORAGE_PROVIDER=r2 时生效）=====
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# ===== 审核邮件快捷链接基础地址 =====
REVIEW_ACTION_BASE_URL=https://yourdomain.com

# ===== 前端 API 地址（用户端）=====
NUXT_PUBLIC_API_BASE=http://localhost:9091/api

# ===== Docker 镜像地址（仅生产环境 docker-compose.prod.yml 使用）=====
# 格式：ghcr.io/<GitHub用户名>/<仓库名>/<镜像名>:latest
# DOCKER_IMAGE_API=ghcr.io/your-username/weblog/weblog-api:latest
# DOCKER_IMAGE_USER=ghcr.io/your-username/weblog/weblog-user:latest
