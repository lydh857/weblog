# 生产环境密钥模板（复制后按实际值填写，不要提交到仓库）
# 建议复制为：/opt/weblog/.env.prod

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=weblog_prod
DB_PASSWORD=CHANGE_TO_STRONG_DB_PASSWORD

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_TO_STRONG_REDIS_PASSWORD

# JWT / CAPTCHA（必须强随机，至少 32 字符）
# 生成命令示例：openssl rand -base64 64
JWT_SECRET=CHANGE_TO_STRONG_RANDOM_JWT_SECRET
CAPTCHA_SECRET_KEY=CHANGE_TO_STRONG_RANDOM_CAPTCHA_SECRET

# OAuth（生产专用，不复用开发凭据）
GITHUB_CLIENT_ID=CHANGE_TO_PROD_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_TO_PROD_CLIENT_SECRET

# CORS
CORS_ORIGINS=https://yourdomain.com

# 可选：AI
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
